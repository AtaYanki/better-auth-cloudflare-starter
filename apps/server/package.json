{
	"name": "server",
	"main": "src/index.ts",
	"type": "module",
	"scripts": {
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "wrangler dev --port 3000",
		"start": "wrangler dev",
		"test": "vitest run",
		"test:watch": "vitest",
		"deploy": "wrangler deploy --env production",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings"
	},
	"dependencies": {
		"@better-auth-cloudflare-starter/api": "workspace:*",
		"@better-auth-cloudflare-starter/auth": "workspace:*",
		"@better-auth-cloudflare-starter/db": "workspace:*",
		"@better-auth-cloudflare-starter/sync": "workspace:*",
		"@hono/trpc-server": "^0.4.2",
		"@trpc/server": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"hono": "catalog:",
		"hono-rate-limiter": "^0.5.3",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@better-auth-cloudflare-starter/config": "workspace:*",
		"@cloudflare/vitest-pool-workers": "^0.8.0",
		"@types/node": "catalog:",
		"typescript": "catalog:",
		"vitest": "~3.2.0",
		"wrangler": "catalog:"
	}
}
